# Copy to .env and fill in real values. NEVER commit the real .env.

# Postgres connection string. Locally, use a Neon dev branch or a local Postgres.
# On Vercel, set this in Project Settings > Environment Variables.
# Use Neon's POOLED connection string (host contains "-pooler") for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign sessions/JWTs. Generate with: openssl rand -base64 32
SESSION_SECRET="generate-a-random-32-char-string"

# Anthropic API key (server-side only). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."
